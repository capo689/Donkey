---
import Base from '../../layouts/Base.astro';
---
<Base title="The Laboratory" description="The Laboratory has been retired; its useful contents have moved.">
  <meta http-equiv="refresh" content="0; url=/evolution" slot="head" />
  <main class="shell" style="padding:80px 20px;text-align:center;">
    <p style="font-family:'Old Standard TT', serif;font-size:18px;line-height:1.6;max-width:560px;margin:0 auto;">
      The Laboratory has been retired. Its contents have moved:
    </p>
    <ul style="list-style:none;padding:0;margin:24px auto;max-width:520px;font-family:'Old Standard TT',serif;line-height:1.7;text-align:left;">
      <li>&middot; The Paper II roadmap is superseded by <a href="/evolution">The Evolution</a>.</li>
      <li>&middot; Code &amp; data have moved to <a href="/code-and-data">/code-and-data</a>.</li>
      <li>&middot; Phase memos have moved to <a href="/field-notes/phase-memos">/field-notes/phase-memos</a>.</li>
    </ul>
    <p style="font-family:'Old Standard TT', serif;font-style:italic;color:var(--ink-soft);">Redirecting to <a href="/evolution">The Evolution</a>&hellip;</p>
  </main>
</Base>
<script is:inline>window.location.replace('/evolution');</script>
