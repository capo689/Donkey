---
import Manuscript from '../../layouts/Manuscript.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('papers', 'paper-3-appendix-a');
if (!entry) throw new Error('paper-3-appendix-a not found');
const { Content } = await render(entry);
---

<Manuscript
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  pageTitle="Paper III — Appendix A"
  eyebrow="THE PAPER · APPENDIX A"
  breadcrumbLabel="Appendix A"
>
  <Content />
</Manuscript>
