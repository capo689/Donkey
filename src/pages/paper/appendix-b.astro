---
import Manuscript from '../../layouts/Manuscript.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('papers', 'paper-3-appendix-b');
if (!entry) throw new Error('paper-3-appendix-b not found');
const { Content } = await render(entry);
---

<Manuscript
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  pageTitle="Paper III — Appendix B"
  eyebrow="THE PAPER · APPENDIX B"
  breadcrumbLabel="Appendix B"
>
  <Content />
</Manuscript>
