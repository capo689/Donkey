---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const results = await getCollection('results');
  return results.map((entry) => ({
    params: { result: String(entry.data.resultNumber) },
    props: { entry, all: results },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await render(entry);
const { title, resultNumber, scaling, status, summary } = entry.data;

const ROMAN: Record<number, string> = { 1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V' };
const ORDINAL: Record<number, string> = {
  1: 'Result the First',
  2: 'Result the Second',
  3: 'Result the Third',
  4: 'Result the Fourth',
  5: 'Result the Fifth',
};
const roman = ROMAN[resultNumber];

const sorted = [...all].sort((a, b) => a.data.resultNumber - b.data.resultNumber);
const idx = sorted.findIndex((r) => r.data.resultNumber === resultNumber);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

type Tag = { label: string; cls?: string };
const tagsByResult: Record<number, Tag[]> = {
  1: [{ label: 'Theorem 1', cls: 'featured' }, { label: 'Headline' }, { label: 'Unconditional (Haar)' }],
  2: [{ label: 'Theorem 2', cls: 'featured' }, { label: 'Haar Class' }, { label: 'Unconditional' }, { label: 'No numerical constant' }],
  3: [{ label: 'Theorem 3' }, { label: 'Product Class' }, { label: 'Conditional', cls: 'open' }],
  4: [{ label: 'Integer Gap', cls: 'featured' }, { label: 'αₚ − αₕ = 1' }, { label: 'Open Problem' }],
  5: [{ label: 'Lemma 1' }, { label: 'Structural Identity' }, { label: 'First-moment collapse' }],
};
const tags = tagsByResult[resultNumber] ?? [];
---

<Base title={`Result ${roman}: ${title}`} description={summary}>
  <div class="page">

    <div class="running-head">
      <span class="side">The Donkey on the Edge</span>
      <span class="center">Vol.&thinsp;II&emsp;&middot;&emsp;The Paper&emsp;&middot;&emsp;Result {roman}</span>
      <span class="side right">May MMXXVI</span>
    </div>

    <div class="masthead-compact">
      <a href="/">The Donkey <span class="conn">on the</span> Edge</a>
    </div>

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Masthead</a>
      <span class="sep">&rsaquo;</span>
      <a href="/paper">The Paper</a>
      <span class="sep">&rsaquo;</span>
      <span>Results</span>
      <span class="sep">&rsaquo;</span>
      <span class="current">Result {roman}</span>
    </nav>

    <header class="hero">
      <div class="hero-numeral" aria-hidden="true">{roman}</div>
      <div class="hero-content">
        <div class="hero-eyebrow">{ORDINAL[resultNumber]}</div>
        <h1 class="hero-headline">{title}</h1>

        <div class="cartouche">
          <p class="cartouche-text">{summary}</p>
        </div>

        <div class="hero-tags">
          {tags.map((t) => (
            <span class={`tag${t.cls ? ' ' + t.cls : ''}`} set:html={t.label} />
          ))}
        </div>
      </div>
    </header>

    <section aria-labelledby="full-card-heading">
      <div class="section-header">
        <div class="section-label">The result, in full</div>
        <h2 class="section-title" id="full-card-heading">{title}</h2>
      </div>

      <div class="result-detail-body">
        <Content />
      </div>
    </section>

    <section class="xref" aria-label="Cross-references">
      <div class="xref-label">See also</div>
      <div class="xref-grid">
        <div class="xref-item">
          <div class="xref-item-label">Manuscript</div>
          <a href="/paper/full">Paper III, in full &middot; the manuscript browser</a>
          <a href="/paper/appendix-c" style="margin-top:8px;display:block;">Appendix C &middot; the entropy-replacement proof</a>
        </div>
        <div class="xref-item">
          <div class="xref-item-label">The Evolution</div>
          <a href="/evolution">The walk, in three steps</a>
          <a href="/evolution/paper-one" style="margin-top:8px;display:block;">Paper I &middot; preserved</a>
        </div>
        <div class="xref-item">
          <div class="xref-item-label">Field Notes &amp; Reviewer</div>
          <a href="/field-notes/alice-and-bob">Alice and Bob &middot; the plain-English companion</a>
          <a href="/paper/reviewer-note" style="margin-top:8px;display:block;">The Reviewer's Note &middot; Scholar (ChatGPT)</a>
        </div>
      </div>
    </section>

    <nav class="prev-next" aria-label="Result navigation">
      {prev ? (
        <a class="nav-btn" href={`/paper/${prev.data.resultNumber}`}>
          <span class="arrow">&larr;</span>
          <span>
            <span class="label">Previous</span>
            Result {ROMAN[prev.data.resultNumber]}
          </span>
        </a>
      ) : <span />}
      <span class="nav-center">The Paper &middot; Five Results</span>
      {next ? (
        <a class="nav-btn" href={`/paper/${next.data.resultNumber}`}>
          <span>
            <span class="label">Next</span>
            Result {ROMAN[next.data.resultNumber]}
          </span>
          <span class="arrow">&rarr;</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</Base>

<style>
  .result-detail-body {
    max-width: 760px;
    margin: 24px auto 48px;
    padding: 0 var(--s4);
    font-family: 'Old Standard TT', serif;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink);
  }
  .result-detail-body p { margin: 0 0 1em; text-align: justify; hyphens: auto; }
  .result-detail-body strong { color: var(--ink); }
  .result-detail-body em { color: var(--ink); }
  .result-detail-body ul { padding-left: 1.2em; margin: 1em 0; }
  .result-detail-body li { margin-bottom: 0.5em; }
  .result-detail-body .katex-display { margin: 1.4em 0; }
</style>
