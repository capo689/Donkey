---
import Manuscript from '../../layouts/Manuscript.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('papers', 'paper-3-appendix-c');
if (!entry) throw new Error('paper-3-appendix-c not found');
const { Content } = await render(entry);
---

<Manuscript
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  pageTitle="Paper III — Appendix C"
  eyebrow="THE PAPER · APPENDIX C"
  breadcrumbLabel="Appendix C"
>
  <Content />
</Manuscript>
