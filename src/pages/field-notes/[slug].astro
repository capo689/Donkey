---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, subtitle, date, backdated, voice, section } = entry.data;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const sectionLabel = section === 'method' ? 'The Method' : 'Field Notes';
---

<Base title={title}>
  <a href="#main" class="skip">Skip to article</a>

  <div class="shell">

    <!-- RUNNING HEAD -->
    <div class="running-head">
      <a class="rh-mark" href="/"><span class="arr">&larr;</span>The Donkey on the Edge</a>
      <div class="rh-meta">
        <span>Vol. II</span>
        <span class="dot"></span>
        <span>{sectionLabel}</span>
        <span class="dot"></span>
        <time datetime={date.toISOString()}>{dateStr}</time>
      </div>
    </div>

    <!-- ARTICLE -->
    <article id="main">

      <header class="article-preamble">
        <div class="article-section">{sectionLabel} &nbsp;&middot;&nbsp; {dateStr}</div>
        <h1 class="article-title">{title}</h1>
        {subtitle && (
          <p class="article-subtitle">{subtitle}</p>
        )}

        <div class="article-byline">
          <span class="article-byline-mark" aria-hidden="true"></span>
          <div class="article-byline-text">
            <p class="article-byline-name">By Adam R. Cagle</p>
            <p class="article-byline-meta">
              with <em>Claude</em> of Anthropic, as computational collaborator
              <span> &middot; </span>
              <time datetime={date.toISOString()}>{dateStr}</time>
            </p>
          </div>
        </div>
      </header>

      <div class="article-open-ornament" aria-hidden="true">
        <span class="ln"></span>
        <span class="mark">&#10086;</span>
        <span class="ln"></span>
      </div>

      <div class={`article-body is-lede${voice === 'paper' ? ' paper-voice' : ''}`}>
        <Content />
      </div>

      <!-- END ORNAMENT -->
{backdated && (
        <div class="backdating">
          Written in May 2026, backdated to when the work happened.<br>
          This article is a reflection, not a contemporaneous journal entry.
        </div>
      )}

      <!-- RELATED -->
      <section class="related" aria-labelledby="related-head">
        <header class="related-head">
          <h2 class="related-head-mark" id="related-head">Also in this Volume</h2>
          <p class="related-head-sub">further articles bearing on the same matter</p>
        </header>
        <div class="related-list">
          <a class="related-entry" href="/paper">
            <span class="related-num">i.</span>
            <div>
              <h3 class="related-title">Paper III &middot; the featured paper.</h3>
              <p class="related-sub">The Paper &middot; the entropy-replacement theorem, the Haar law unconditional, the integer gap.</p>
            </div>
            <span class="related-page">Read &nbsp;&sect; I</span>
          </a>
          <a class="related-entry" href="/evolution">
            <span class="related-num">ii.</span>
            <div>
              <h3 class="related-title">The Evolution &middot; three papers in five figures.</h3>
              <p class="related-sub">The Evolution &middot; what each paper got, what each was missing, and the reviewer who drove the last advance.</p>
            </div>
            <span class="related-page">Read &nbsp;&sect; II</span>
          </a>
          <a class="related-entry" href="/field-notes">
            <span class="related-num">iii.</span>
            <div>
              <h3 class="related-title">Field Notes &middot; the notebook, open.</h3>
              <p class="related-sub">Field Notes &middot; phase memos, work posts, essays, and two plain-English explainers.</p>
            </div>
            <span class="related-page">Read &nbsp;&sect; IV</span>
          </a>
          <a class="related-entry" href="/method">
            <span class="related-num">iv.</span>
            <div>
              <h3 class="related-title">The Method &middot; on the doing of this sort of work.</h3>
              <p class="related-sub">The Method &middot; thesis, protocol, calibration, and the per-paper method &ndash; Scholar included.</p>
            </div>
            <span class="related-page">Read &nbsp;&sect; V</span>
          </a>
        </div>
      </section>

    </article>

    <!-- COMPACT FOOTER -->
    <footer class="foot">
      <p class="foot-title">The Donkey <span class="foot-title-conn">on the</span> Edge</p>
      <p class="foot-strap">A Naturalist's Record &middot; Vol. II, No. I &middot; May 2026</p>
      <div class="foot-rule" aria-hidden="true">
        <span class="foot-rule-ln"></span>
        <span class="foot-rule-mark">&#8290;</span>
        <span class="foot-rule-ln"></span>
      </div>
      <nav class="foot-links" aria-label="Footer links">
        <a href="/">Masthead</a>
        <a href="/field-notes">Field Notes Contents</a>
        <a href="/about#citation">Cite</a>
        <a href="mailto:adamrcagle@gmail.com">Correspondence</a>
      </nav>
      <p class="foot-meta">&copy; 2026 &middot; Bend, Oregon</p>
    </footer>
  </div>
</Base>
