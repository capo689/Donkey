---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, date, backdated, voice, section } = entry.data;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={title}>
  <!-- Layout: Essay.astro (from mockup_2_essay.html) -->
  <main class="shell">
    <header class="running-head">
      <span class="rh-mark">Field Notes</span>
      <span class="rh-meta">{dateStr}</span>
    </header>

    <article class={`article-body ${voice === 'paper' ? 'paper-voice' : ''}`}>
      <header>
        <h1 class="article-title">{title}</h1>
        <div class="article-byline">
          <span class="article-byline-name">Adam Cagle</span>
          <span class="article-byline-meta">with Claude (Anthropic), computational collaborator</span>
          <time class="article-byline-meta" datetime={date.toISOString()}>{dateStr}</time>
        </div>
      </header>

      {backdated && (
        <p class="backdating">Written in May 2026, backdated to when the work happened. This post is a reflection, not a contemporaneous journal entry.</p>
      )}

      <div class="article-open-ornament"></div>

      <Content />

      <div class="end-ornament"></div>
    </article>
  </main>
</Base>
