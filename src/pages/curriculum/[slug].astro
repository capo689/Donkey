---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stations = await getCollection('curriculum');
  const stationByNumber = new Map(stations.map((s) => [s.data.stationNumber, s]));
  return stations.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, stationByNumber },
  }));
}

const { entry, stationByNumber } = Astro.props;
const { Content } = await render(entry);
const { title, stationNumber, classReportTitle, date, backdated, prerequisites, extendsTo, line } = entry.data;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const lookup = (n: number) => {
  const s = stationByNumber.get(n);
  return s ? { href: `/curriculum/${s.id}`, label: s.data.classReportTitle, num: n } : null;
};
const prereqLinks = prerequisites.map(lookup).filter((x): x is NonNullable<typeof x> => x !== null);
const extendsLinks = extendsTo.map(lookup).filter((x): x is NonNullable<typeof x> => x !== null);
---

<Base title={classReportTitle} description={`Class Report ${stationNumber}: ${classReportTitle}`}>
  <!-- Layout: ClassReport.astro (from mockup_6_class_report.html) -->
  <main class="shell">
    <header class="station-identity">
      <p class="station-eyebrow">Class Report</p>
      <span class="station-numeral">{String(stationNumber).padStart(2, '0')}</span>
      <h1 class="station-title">{classReportTitle}</h1>
      <p class="station-subtitle">{title}</p>
      <p class="station-line-name">{line}</p>
    </header>

    {backdated && (
      <p class="backdating">Written in May 2026, backdated to when the work happened. This post is a reflection, not a contemporaneous journal entry.</p>
    )}

    {prereqLinks.length > 0 && (
      <div class="prereq-col">
        <p class="prereq-col-head">Prerequisites</p>
        {prereqLinks.map((p) => (
          <a href={p.href} class="prereq-item">
            <span class="prereq-number">{String(p.num).padStart(2, '0')}</span>
            <span class="prereq-body"><span class="prereq-name">{p.label}</span></span>
          </a>
        ))}
      </div>
    )}

    <article class="article-body main-col">
      <Content />
    </article>

    {extendsLinks.length > 0 && (
      <div class="connections">
        <p class="connections-head">Extends to</p>
        <div class="connections-grid">
          {extendsLinks.map((p) => (
            <div class="conn-item">
              <p class="conn-type">Station {String(p.num).padStart(2, '0')}</p>
              <a href={p.href} class="conn-link">{p.label}</a>
            </div>
          ))}
        </div>
      </div>
    )}
  </main>
</Base>
